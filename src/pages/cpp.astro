---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@utils/content-utils";

const allPosts = await getSortedPostsList();
const cppPosts = allPosts
  .filter((post) => post.data.category === "C++")
  .sort((a, b) => (a.data.priority ?? 99) - (b.data.priority ?? 99));
---

<MainGridLayout title="C++">
  <div class="card-base px-8 py-6 mb-4">
    <h1 class="text-3xl font-bold mb-2">C++ Programming</h1>
    <p class="text-50">A structured guide to learning C++, chapter by chapter.</p>
  </div>

  {cppPosts.length === 0 && (
    <div class="card-base px-8 py-6">
      <p class="text-50">No posts in this section yet.</p>
    </div>
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {cppPosts.map((post, index) => {
      const date = new Date(post.data.published);
      const dateStr = date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
      return (
        <a
          href={post.url}
          class="card-base px-6 py-5 flex flex-col gap-2 hover:border-[var(--primary)] transition-colors"
        >
          <div class="flex items-center gap-2 text-sm text-50">
            <span class="font-bold text-[var(--primary)]">
              Chapter {String(index + 1).padStart(2, '0')}
            </span>
            <span>·</span>
            <span>{dateStr}</span>
          </div>
          <h2 class="font-bold text-lg text-75">{post.data.title}</h2>
          <p class="text-sm text-50 line-clamp-2">{post.data.description}</p>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-1">
              {post.data.tags.slice(0, 3).map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded-md bg-[var(--btn-plain-bg)] text-50">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </a>
      );
    })}
  </div>
</MainGridLayout>
