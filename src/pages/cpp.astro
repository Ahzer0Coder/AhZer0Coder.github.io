---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@utils/content-utils";

const allPosts = await getSortedPostsList();
const cppPosts = allPosts
  .filter((post) => post.data.category === "C++")
  .sort((a, b) => (a.data.priority ?? 99) - (b.data.priority ?? 99));
---

<MainGridLayout title="C++">
  <div class="card-base px-8 py-6 mb-6">
    <h1 class="text-3xl font-bold mb-2">C++ Programming</h1>
    <p class="text-50">A structured guide to learning C++, chapter by chapter.</p>
  </div>

  {cppPosts.length === 0 && (
    <div class="card-base px-8 py-6">
      <p class="text-50">No posts in this section yet.</p>
    </div>
  )}

  <div class="flex flex-col gap-3">
    {cppPosts.map((post, index) => {
      const date = new Date(post.data.published);
      const dateStr = date.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
      return (
        <a
          href={post.url}
          class="group card-base px-5 py-4 flex items-center gap-4 hover:border-[var(--primary)] transition-all duration-200"
        >
          {/* Index badge */}
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-[var(--primary)] flex items-center justify-center text-white font-bold text-sm">
            {String(index + 1).padStart(2, '0')}
          </div>

          {/* Thumbnail */}
          {post.data.image && (
            <div class="flex-shrink-0 w-16 h-12 rounded-lg overflow-hidden bg-[var(--btn-plain-bg)]">
              <img
                src={post.data.image}
                alt={post.data.title}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </div>
          )}

          {/* Content */}
          <div class="flex-1 min-w-0">
            <h2 class="font-bold text-75 group-hover:text-[var(--primary)] transition-colors truncate">
              {post.data.title}
            </h2>
            <p class="text-sm text-50 line-clamp-1 mt-0.5">{post.data.description}</p>
            <p class="text-xs text-40 mt-1">{dateStr}</p>
          </div>

          {/* Arrow */}
          <div class="flex-shrink-0 text-40 group-hover:text-[var(--primary)] transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </div>
        </a>
      );
    })}
  </div>
</MainGridLayout>
