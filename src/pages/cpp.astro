---
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@utils/content-utils";

const allPosts = await getSortedPostsList();
const cppPosts = allPosts
  .filter((post) => post.data.category === "C++")
  .sort((a, b) => (a.data.priority ?? 99) - (b.data.priority ?? 99));
---

<MainGridLayout title="C++">
  <div class="card-base px-8 py-6">
    <h1 class="text-3xl font-bold mb-2">C++ Programming</h1>
    <p class="mb-8 text-50">A structured guide to learning C++, chapter by chapter.</p>

    <div class="space-y-4">
      {cppPosts.map((post, index) => (
        <a
          href={post.url}
          class="block p-4 rounded-xl border border-[var(--line-divider)] hover:border-[var(--primary)] transition-colors"
        >
          <div class="flex items-center gap-4">
            <span class="text-2xl font-bold text-[var(--primary)]">
              {String(index + 1).padStart(2, '0')}
            </span>
            <div>
              <h2 class="font-bold text-75">{post.data.title}</h2>
              <p class="text-sm text-50 mt-1">{post.data.description}</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    {cppPosts.length === 0 && (
      <p class="text-50">No posts in this section yet.</p>
    )}
  </div>
</MainGridLayout>
